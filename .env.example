# Backend (local dev, pointing at the Compose Postgres published on host port 5433).
# Inside docker-compose the backend uses the in-network host instead: db:5432.
DATABASE_URL=postgresql+psycopg://fleet:fleet@localhost:5433/fleet

# Comma-separated CORS origins (the Vite dev server).
CORS_ORIGINS=http://localhost:5173

# Frontend: base URL the dashboard calls.
VITE_API_BASE=http://localhost:8000
